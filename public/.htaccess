# rewards-foundry.com — Apache config
#
# SG handles HTTPS redirect + compression at the panel layer; this
# file focuses on URL hygiene + headers.

# Vanity URL: /redeem → /redeem.html. Redemption traffic comes in
# via printed-QR URLs that omit the .html suffix.
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ /$1.html [L]

# Strip referrer noise on outbound (the redemption page may link
# users to a partner site; we don't want to leak the token).
<IfModule mod_headers.c>
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header unset X-Powered-By
  Header unset Server
</IfModule>

# Cache static assets for a week. HTML is excluded — it has no ?v=
# versioning, so caching let SG's edge cache serve a stale redemption
# page after an edit. See the no-store block below.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png            "access plus 7 days"
  ExpiresByType image/jpeg           "access plus 7 days"
  ExpiresByType image/svg+xml        "access plus 7 days"
  ExpiresByType image/webp           "access plus 7 days"
  ExpiresByType font/woff2           "access plus 30 days"
  ExpiresByType text/css             "access plus 1 day"
  ExpiresByType application/javascript "access plus 1 day"
</IfModule>

# 2026-07-03 — Force no-store on HTML so the SG edge cache never masks
# an edit with a stale document. Ctrl+Shift+R reuses the same edge key
# so it doesn't help; only a ?v= query (a new key) dodged it.
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
    Header always unset ETag
    FileETag None
  </FilesMatch>
</IfModule>
